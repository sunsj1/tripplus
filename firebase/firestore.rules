rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    /// Community station pulses — read by anyone signed in; create only with own uid.
    match /stationCommunityReports/{docId} {
      /// Public read so route lists / previews work before sign-in flows complete.
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.reporterUserId == request.auth.uid
        && request.resource.data.stationKey is string
        && request.resource.data.stationKey.size() > 0
        && request.resource.data.stationKey.size() < 900
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.condition is string;
      allow update, delete: if false;
    }
  }
}
